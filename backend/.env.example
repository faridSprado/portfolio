# ===========================================
# Backend Environment Variables
# ===========================================
# Copy this file to .env or set in Dokploy.
# NEVER commit real secrets.

# Gemini API from Google AI Studio.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.55
GEMINI_MAX_OUTPUT_TOKENS=2500

# Private content editor.
ADMIN_SECRET=change-this-admin-secret
# ADMIN_TOKEN is also accepted as a compatibility alias for local development.
PORTFOLIO_CONTENT_PATH=../data/portfolio_content.json

# Contact form email
RESEND_API_KEY=
RESEND_FROM_EMAIL="Portfolio Farid <onboarding@resend.dev>"
CONTACT_EMAIL=faridvzx@gmail.com

# Public API token bootstrap used by the frontend.
SECRET_KEY=change-this-with-a-secure-random-key-min-32-chars
CLIENT_ID=portfolio-client
CLIENT_SECRET=change-this-client-secret

# CORS
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://faridprado.dev,https://www.faridprado.dev
